ATIRF_ENV=development
ATIRF_DATABASE_URL=sqlite:///./atirf.db
ATIRF_ENABLE_DEMO_ROUTES=true
ATIRF_REQUIRE_API_KEY=false
ATIRF_API_KEY=change-me
ATIRF_ALLOWED_ORIGINS=*
ATIRF_CORRELATION_WINDOW_MINUTES=240
ATIRF_OLLAMA_ENABLED=false
ATIRF_OLLAMA_HOST=http://127.0.0.1:11434
ATIRF_OLLAMA_MODEL=llama3.1:8b
ATIRF_OLLAMA_TIMEOUT_SECONDS=90
ATIRF_RANSOMWARE_LIVE_ENABLED=false
ATIRF_RANSOMWARE_LIVE_BASE_URL=https://api.ransomware.live/v2
ATIRF_RANSOMWARE_LIVE_TIMEOUT_SECONDS=30
